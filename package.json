{
  "name": "aether",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "lint": "tsc && eslint .",
    "client:dev": "npm run dev -w @aether/client",
    "client:build": "npm run build -w @aether/client",
    "client:preview": "npm run preview -w @aether/client",
    "web:dev": "npm run dev -w @aether/web",
    "web:build": "npm run build -w @aether/web",
    "web:preview": "npm run preview -w @aether/web",
    "server:kill:unix": "kill -9 $(lsof -i :3000) &>/dev/null | exit 0",
    "server:kill:win": "",
    "server:kill": "node -e \"require('child_process').execSync(process.platform.startsWith('win') ? 'npm run server:kill:win' : 'npm run server:kill:unix')\"",
    "server:dev": "ts-node -r dotenv/config --files server/main.ts",
    "server:watch": "nodemon --watch \"server/**\" --watch \"shared/**\" --ext \"ts,js,json\" --inspect --exec \"npm run server:kill && npm run server:dev\"",
    "clean": "rm -rf node_modules",
    "server:build": "node -r dotenv/config build.server.js",
    "server:run": "node -r dotenv/config --optimize-for-size --max-old-space-size=512 dist/server.js",
    "test": "vitest"
  },
  "workspaces": [
    "ui",
    "web",
    "shared",
    "client"
  ],
  "dependencies": {
    "@tanstack/react-query": "^5.95.2",
    "canvas": "^3.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "easystarjs": "^0.4.4",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "http-proxy-middleware": "^3.0.5",
    "jsdom": "^29.0.1",
    "lodash": "^4.17.23",
    "mongodb": "^7.1.1",
    "nanoid": "^5.1.7",
    "peer": "^1.0.2",
    "peerjs": "^1.5.5",
    "phaser": "^3.90.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-tooltip": "^5.30.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "theme-ui": "^0.17.4",
    "use-double-tap": "^1.3.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.3.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "8.57.3-alpha.3",
    "vite": "^7.1.0",
    "vitest": "^4.1.2"
  }
}
